# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.jpg binary
*.png binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Docker files
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Jenkins files
Jenkinsfile text eol=lf

# Python files
*.py text eol=lf

# SQL files
*.sql text eol=lf
